{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "basedpyright-lsp@kausal-backend-plugins": true
  },
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "extraKnownMarketplaces": {
    "kausal-backend-plugins": {
      "source": {
        "path": "./kausal_common/development/claude",
        "source": "directory"
      }
    }
  },
  "hooks": {},
  "permissions": {
    "allow": [
      "WebFetch",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(uv:*)",
      "Bash(find:*)",
      "Bash(mv:*)",
      "Bash(ls:*)",
      "Bash(uvx turms:*)",
      "mcp__sentry__update_issue",
      "Bash(kausal_common/development/tools/generate-mcp-schema.sh:*)"
    ]
  }
}
