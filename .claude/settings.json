{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(uv:*)",
      "Bash(find:*)",
      "Bash(mv:*)",
      "Bash(ls:*)"
    ]
  },
  "enabledPlugins": {
    "basedpyright-lsp@kausal-backend-plugins": true
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "ENABLE_LSP_TOOL": "1"
  },
  "extraKnownMarketplaces": {
    "kausal-backend-plugins": {
      "source": {
        "source": "directory",
        "path": "./kausal_common/development/claude"
      }
    }
  },
  "hooks": {
  }
}
